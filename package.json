{
  "name": "nyro",
  "version": "1.0.1",
  "description": "YouTube audio downloader with queue management",
  "main": "out/main/index.js",
  "author": {
    "name": "Nyro",
    "email": "app@nyro.app"
  },
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && electron-builder",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.renderer.json",
    "lint": "eslint src --ext .ts,.vue"
  },
  "dependencies": {
    "@vueuse/core": "^10.9.0",
    "electron-store": "^8.1.0",
    "node-id3": "^0.2.6",
    "pinia": "^2.1.0",
    "uuid": "^11.1.0",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0",
    "vue-virtual-scroller": "^2.0.0-beta.8"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/node": "^20.11.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/tsconfig": "^0.5.0",
    "autoprefixer": "^10.4.17",
    "electron": "^35.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.0.0",
    "playwright-core": "^1.60.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  },
  "build": {
    "appId": "com.nyro.app",
    "productName": "Nyro",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "resources/",
        "to": "resources/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "branding/icons/nyro-512.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "linux": {
      "icon": "branding/icons",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "AudioVideo"
    },
    "mac": {
      "icon": "branding/icons/nyro-1024.png",
      "target": [
        "dmg"
      ],
      "category": "public.app-category.music"
    },
    "files": [
      "out/**/*",
      "package.json"
    ]
  }
}
